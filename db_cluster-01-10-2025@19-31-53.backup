--
-- Name: email_feedbacks Enable insert for authenticated users only; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Enable insert for authenticated users only" ON public.email_feedbacks FOR INSERT TO anon WITH CHECK (true);


--
-- Name: draft_versions Users can create draft versions for their drafts; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can create draft versions for their drafts" ON public.draft_versions FOR INSERT WITH CHECK ((EXISTS ( SELECT 1
   FROM public.drafts
  WHERE ((drafts.id = draft_versions.draft_id) AND (drafts.user_id = auth.uid())))));


--
-- Name: brands Users can create their own brands; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can create their own brands" ON public.brands FOR INSERT WITH CHECK ((auth.uid() = user_id));


--
-- Name: drafts Users can create their own drafts; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can create their own drafts" ON public.drafts FOR INSERT WITH CHECK ((auth.uid() = user_id));


--
-- Name: email_feedbacks Users can create their own feedbacks; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can create their own feedbacks" ON public.email_feedbacks FOR INSERT WITH CHECK ((auth.uid() = user_id));


